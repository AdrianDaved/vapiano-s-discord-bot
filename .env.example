# ──────────────────────────────────────────────
# Bot Configuration
# ──────────────────────────────────────────────
BOT_TOKEN=          # Token del bot (Discord Developer Portal → Bot → Token)
CLIENT_ID=          # Application ID (Discord Developer Portal → General Information)
CLIENT_SECRET=      # Client Secret (Discord Developer Portal → OAuth2)

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vapiano

# ──────────────────────────────────────────────
# API / Dashboard
# ──────────────────────────────────────────────
API_PORT=3001
API_SECRET=          # Secreto largo y aleatorio para firmar JWT  (openssl rand -hex 32)
SESSION_SECRET=      # Secreto largo y aleatorio para sesiones    (openssl rand -hex 32)

# URL pública del servidor en producción (bot + API + dashboard corren juntos)
# Ejemplo: https://tudominio.com  o  http://IP:3001
DASHBOARD_URL=http://localhost:3001
API_URL=http://localhost:3001

# ──────────────────────────────────────────────
# Discord OAuth2
# ──────────────────────────────────────────────
# Discord Developer Portal → OAuth2 → Redirects → añade esta URL
OAUTH2_REDIRECT_URI=http://localhost:3001/auth/callback

# ──────────────────────────────────────────────
# Environment
# ──────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
