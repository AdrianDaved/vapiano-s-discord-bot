# ──────────────────────────────────────────────
# Bot Configuration
# ──────────────────────────────────────────────
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id
CLIENT_SECRET=your_discord_application_client_secret

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
# For local development:
DATABASE_URL=postgresql://vapiano:password@localhost:5432/vapiano_bot?schema=public
# Docker Compose overrides this automatically to use the postgres container.

# Docker Compose uses these to create the database:
POSTGRES_USER=vapiano
POSTGRES_PASSWORD=password
POSTGRES_DB=vapiano_bot

# ──────────────────────────────────────────────
# API / Dashboard
# ──────────────────────────────────────────────
API_PORT=3001
API_SECRET=generate_a_long_random_string_here
SESSION_SECRET=generate_another_long_random_string_here

# In production, set these to your real domain:
DASHBOARD_URL=http://localhost:5173
API_URL=http://localhost:3001

# Port the dashboard is exposed on in Docker (default: 80)
DASHBOARD_PORT=80

# ──────────────────────────────────────────────
# Discord OAuth2
# ──────────────────────────────────────────────
# In production, set to your domain: https://yourdomain.com/auth/callback
OAUTH2_REDIRECT_URI=http://localhost:3001/auth/callback

# ──────────────────────────────────────────────
# Environment
# ──────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
