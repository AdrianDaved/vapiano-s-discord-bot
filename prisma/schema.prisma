// Prisma schema for Vapiano Bot - all modules
// PostgreSQL as the backing database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Guild Configuration ─────────────────────────────────────
model GuildConfig {
  id        String   @id // Discord guild ID
  prefix    String   @default("!")
  language  String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Module toggles
  invitesEnabled    Boolean @default(false)
  moderationEnabled Boolean @default(false)
  automodEnabled    Boolean @default(false)
  ticketsEnabled    Boolean @default(false)
  automationEnabled Boolean @default(false)
  welcomeEnabled    Boolean @default(false)
  farewellEnabled   Boolean @default(false)
  reputationEnabled Boolean @default(false)
  giveawayEnabled   Boolean @default(false)
  rifaEnabled        Boolean @default(true)
  rifaCategoryId     String? @default("1489245171953434805")
  rifaPanelChannelId String?
  rifaPanelMessageId String?
  rifaLogChannelId   String?
  rifaStaffRoleIds   String[] @default([])
  suggestionsEnabled Boolean @default(false)
  starboardEnabled  Boolean @default(false)
  afkEnabled        Boolean @default(true)
  backupEnabled     Boolean @default(true)
  stickyEnabled     Boolean @default(true)
  loggingEnabled    Boolean @default(false)

  // Module role restrictions: { "moderation": ["roleId1", ...], "tickets": ["roleId2"] }
  moduleAllowedRoles Json @default("{}")

  // Welcome / Farewell
  welcomeChannelId  String?
  welcomeMessage    String? @default("Bienvenido {user} !")
  welcomeImageEnabled Boolean @default(false)
  farewellChannelId String?
  farewellMessage   String? @default("Goodbye {user}, we'll miss you!")

  // Moderation
  modLogChannelId     String?
  warnLogChannelId    String? // dedicated channel for warnings
  messageLogChannelId String?
  joinLeaveLogChannelId String?
  auditLogChannelId   String? // server changes: roles, channels, etc.
  voiceLogChannelId   String? // voice activity logging
  verificationLogChannelId String? // log channel for /verificacion command
  darRangoRoles         Json?   // [{id,pattern,emoji,message}] dynamic role patterns
  // ─── Levels/XP ─────────────────────────────
  // ─── Server Stats Channels ─────────────────
  statsChannels         Json?    // [{id,channelId,type,format}]
  muteRoleId          String?

  // Tickets
  ticketCategoryId       String?
  ticketLogChannelId     String?
  ticketStaffRoleIds     String[] @default([])
  ticketCounter          Int      @default(0)
  ticketTranscriptChannelId String? // global transcript channel
  ticketCloseConfirmation Boolean @default(true)
  ticketDMTranscript     Boolean @default(true)

  // Auto-roles on join
  joinRoleIds String[] @default([])

  // Anti-spam / AutoMod
  antiSpamEnabled   Boolean @default(false)
  antiSpamThreshold Int     @default(5)  // messages
  antiSpamInterval  Int     @default(5)  // seconds
  antiFloodEnabled  Boolean @default(false)
  antiCapsEnabled   Boolean @default(false)
  antiCapsThreshold Int     @default(70) // percentage
  antiLinksEnabled  Boolean @default(false)
  antiLinksWhitelist String[] @default([])
  blacklistEnabled  Boolean @default(false)
  blacklistedWords  String[] @default([])
  antiCapsMinLength Int     @default(10) // min message length for caps check
  automodExemptRoleIds String[] @default([])
  automodExemptChannelIds String[] @default([])

  // Reputation
  repCooldown       Int     @default(86400) // unused — kept for backwards compat
  repChannelId      String? // optional: restrict rep to this channel

  // Starboard
  starboardChannelId String?
  starboardEmoji     String  @default("⭐")
  starboardThreshold Int     @default(3) // reactions needed to post

  // Suggestions
  suggestionsChannelId String?
  suggestionsLogChannelId String? // where accepted/denied get logged

  // Relations
  invites       Invite[]
  backups       Backup[]
  warnings      Warning[]
  modActions    ModAction[]
  reactionRoles ReactionRole[]
  autoResponses AutoResponse[]
  scheduledMsgs ScheduledMessage[]
  ticketPanels  TicketPanel[]
  tickets       Ticket[]
  polls         Poll[]
  reputations   Reputation[]
  giveaways     Giveaway[]
  rifas          Rifa[]
  commandPermissions CommandPermission[]
  suggestions   Suggestion[]
  starboardEntries StarboardEntry[]
  afkStatuses    AfkStatus[]
  stickyMessages StickyMessage[]

  @@map("guild_configs")
}

// ─── Invites Module ──────────────────────────────────────────
model Invite {
  id        String   @id @default(uuid())
  guildId   String
  guild     GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  inviterId String   // Discord user ID of the inviter
  invitedId String   // Discord user ID of the invited user
  code      String   // Invite code
  fake      Boolean  @default(false)
  left      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId, inviterId])
  @@index([guildId, invitedId])
  @@map("invites")
}

// ─── Backup Module ───────────────────────────────────────────
model Backup {
  id          String   @id @default(uuid())
  guildId     String
  guild       GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  creatorId   String   // Discord user ID
  name        String
  data        Json     // Full serialized guild config
  size        Int      @default(0) // approximate size in bytes
  createdAt   DateTime @default(now())

  @@index([guildId])
  @@map("backups")
}

// ─── Moderation Module ───────────────────────────────────────
model Warning {
  id        String   @id @default(uuid())
  guildId   String
  guild     GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  moderatorId String
  reason    String   @default("No reason provided")
  createdAt DateTime @default(now())

  @@index([guildId, userId])
  @@map("warnings")
}

model ModAction {
  id          String   @id @default(uuid())
  guildId     String
  guild       GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId      String
  moderatorId String
  action      String   // warn, mute, kick, ban, tempmute, tempban, unmute, unban
  reason      String   @default("No reason provided")
  duration    Int?     // in seconds, for temp actions
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([guildId, userId])
  @@index([expiresAt])
  @@map("mod_actions")
}

// ─── Reaction / Button Roles ─────────────────────────────────
model ReactionRole {
  id        String   @id @default(uuid())
  guildId   String
  guild     GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  messageId String
  emoji     String   // emoji identifier
  roleId    String
  type      String   @default("toggle") // toggle, give, remove

  @@unique([messageId, emoji])
  @@map("reaction_roles")
}

// ─── Automation Module ───────────────────────────────────────
model AutoResponse {
  id        String   @id @default(uuid())
  guildId   String
  guild     GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  trigger   String   // keyword or regex
  response  String   // message to send
  matchType String   @default("contains") // exact, contains, startsWith, regex
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([guildId])
  @@map("auto_responses")
}

model ScheduledMessage {
  id        String   @id @default(uuid())
  guildId   String
  guild     GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  message   String
  cron      String   // cron expression
  enabled   Boolean  @default(true)
  lastRun   DateTime?
  createdAt DateTime @default(now())

  @@index([guildId])
  @@map("scheduled_messages")
}

model Poll {
  id        String     @id @default(uuid())
  guildId   String
  guild     GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  messageId String?
  question  String
  options   String[]   // array of option texts
  votes     Json       @default("{}") // { optionIndex: [userId, ...] }
  creatorId String
  endsAt    DateTime?
  allowedRoleIds String[]   // empty = everyone can vote
  ended     Boolean    @default(false)
  createdAt DateTime @default(now())

  @@map("polls")
}

// ─── Ticket Module ───────────────────────────────────────────
model TicketPanel {
  id          String   @id @default(uuid())
  guildId     String
  guild       GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name        String   @default("Default") // internal panel name

  // Panel embed sent to channel
  channelId   String
  messageId   String?
  title       String   @default("Support Tickets")
  description String   @default("Click the button below to create a ticket.")
  embedColor  String   @default("#5865F2") // hex color for panel embed
  footerText  String?

  // Button / Dropdown styling
  buttonLabel String   @default("Create Ticket")
  buttonEmoji String?  @default("🎫")
  buttonColor String   @default("Primary") // Primary, Secondary, Success, Danger
  style       String   @default("button")  // button, dropdown, command

  // Category settings
  categoryId       String?  // category for open ticket channels
  closedCategoryId String?  // category to move tickets when closed

  // Naming
  namingPattern String @default("ticket-{number}") // {number}, {username}, {userid}

  // Support team
  staffRoleIds   String[] @default([])
  adminRoleIds   String[] @default([]) // can delete, manage panel settings

  // Ticket creation settings
  ticketLimit    Int      @default(1) // max open tickets per user per panel
  mentionStaff   Boolean  @default(true) // ping staff when ticket opens
  mentionCreator Boolean  @default(true) // ping creator in welcome message

  // Welcome message in new ticket
  welcomeTitle   String?  @default("Ticket Opened")
  welcomeMessage String?  @default("Welcome! Please describe your issue.\nA staff member will assist you shortly.")
  welcomeColor   String   @default("#5865F2")

  // Close request flow
  closeRequestEnabled Boolean @default(true) // ask confirmation before closing
  closeRequestMessage String? @default("Are you sure you want to close this ticket?")

  // Claiming
  claimEnabled   Boolean @default(true) // allow staff to claim tickets
  claimLockOthers Boolean @default(false) // only claimer can reply after claim

  // Transcript settings
  transcriptEnabled    Boolean @default(true) // auto-generate transcript on close
  transcriptChannelId  String? // channel to post transcript links
  transcriptDMUser     Boolean @default(true) // DM transcript to ticket creator
  transcriptDMStaff    Boolean @default(false) // DM transcript to claiming staff

  // Logging
  logChannelId String? // override guild-level ticket log

  // Buttons shown in ticket
  showCloseButton     Boolean @default(true)
  showClaimButton     Boolean @default(true)
  showTranscriptButton Boolean @default(true)

  // Form / Modal on creation
  formEnabled    Boolean @default(false)
  formTitle      String? @default("Ticket Form")
  formQuestions  Json?   // array of { label, placeholder, style, required, minLength, maxLength }

  // Escalation
  escalatePanelId String? // panel to escalate to

  // Feedback
  feedbackEnabled Boolean @default(false) // ask rating after close
  feedbackMessage String? @default("How would you rate the support you received?")

  // Auto-close
  panelAutoRepost         Boolean @default(false) // auto-repost panel when a message is sent in channel
  panelAutoRepostCooldown Int     @default(5)     // seconds between reposts (prevents spam)
  panelAutoRepostIgnoreBots Boolean @default(true) // ignore bot messages for repost trigger

  autoCloseHours Int @default(0) // hours of inactivity before auto-close (0 = disabled)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  tickets      Ticket[]
  transcripts  TicketTranscript[]

  @@map("ticket_panels")
}

model Ticket {
  id          String   @id @default(uuid())
  guildId     String
  guild       GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  panelId     String?
  panel       TicketPanel? @relation(fields: [panelId], references: [id], onDelete: SetNull)
  channelId   String   @unique
  userId      String   // ticket creator
  number      Int
  status      String   @default("open") // open, closed, deleted
  topic       String?
  claimedBy   String?  // staff member who claimed it
  closedBy    String?  // who closed it
  closeReason String?
  priority    String   @default("normal") // low, normal, high, urgent
  rating      Int?     // 1-5 feedback rating
  feedback    String?  // optional feedback text
  addedUsers  String[] @default([]) // extra users added to the ticket

  closedAt      DateTime?
  firstResponse DateTime? // when staff first replied
  lastActivityAt DateTime @default(now()) // updated on each message in the ticket
  createdAt     DateTime @default(now())

  transcripts TicketTranscript[]

  @@index([guildId, status])
  @@index([guildId, userId])
  @@map("tickets")
}

model TicketTranscript {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  panelId     String?
  panel       TicketPanel? @relation(fields: [panelId], references: [id])
  guildId     String
  channelId   String
  userId      String   // ticket creator
  closedBy    String?
  messageCount Int     @default(0)
  messages    Json     // array of message objects
  htmlContent String?  @db.Text // pre-rendered HTML transcript
  createdAt   DateTime @default(now())

  @@index([guildId])
  @@index([ticketId])
  @@map("ticket_transcripts")
}

// ─── Reputation Module ──────────────────────────────────────
model Reputation {
  id         String   @id @default(uuid())
  guildId    String
  guild      GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId     String   // user who RECEIVES the rep
  giverId    String   // user who GAVE the rep
  reason     String?
  createdAt  DateTime @default(now())

  @@index([guildId, userId])
  @@index([guildId, giverId])
  @@map("reputations")
}

// ─── Giveaway Module ────────────────────────────────────────
model Giveaway {
  id          String   @id @default(uuid())
  guildId     String
  guild       GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId   String
  messageId   String?
  hostId      String   // user who started the giveaway
  prize       String
  description String?
  winners     Int      @default(1) // number of winners
  entries     String[] @default([]) // user IDs who entered
  winnerIds   String[] @default([]) // selected winner IDs
  endsAt      DateTime
  ended       Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([guildId])
  @@index([endsAt])
  @@map("giveaways")
}

// ─── Suggestion Module ──────────────────────────────────────
model Suggestion {
  id          String   @id @default(uuid())
  guildId     String
  guild       GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId   String
  messageId   String?
  userId      String
  content     String
  status      String   @default("pending") // pending, approved, denied, implemented
  upvotes     String[] @default([]) // user IDs
  downvotes   String[] @default([]) // user IDs
  staffNote   String?
  reviewedBy  String?  // moderator who reviewed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([guildId])
  @@index([guildId, status])
  @@map("suggestions")
}

// ─── Starboard Module ───────────────────────────────────────
model StarboardEntry {
  id              String   @id @default(uuid())
  guildId         String
  guild           GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  originalMsgId   String   // the original message ID
  originalChId    String   // the original channel ID
  starboardMsgId  String?  // the posted starboard message ID
  authorId        String
  stars           Int      @default(0)
  content         String?
  attachmentUrl   String?
  createdAt       DateTime @default(now())

  @@unique([guildId, originalMsgId])
  @@index([guildId])
  @@map("starboard_entries")
}

// ─── AFK Module ─────────────────────────────────────────────
model AfkStatus {
  id        String   @id @default(uuid())
  guildId   String
  guild     GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  reason    String   @default("AFK")
  createdAt DateTime @default(now())

  @@unique([guildId, userId])
  @@map("afk_statuses")
}

// ─── Sticky Message Module ──────────────────────────────────
model StickyMessage {
  id          String   @id @default(uuid())
  guildId     String
  guild       GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId   String   @unique // one sticky per channel
  messageId   String?  // current bot message ID (to delete & re-send)
  title       String?  // embed title
  description String   // embed description / content
  color       String   @default("#5865F2") // embed color hex
  enabled     Boolean  @default(true)
  createdBy   String   // user who set it
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([guildId])
  @@map("sticky_messages")
}

// ─── Reminder Module ────────────────────────────────────────
model Reminder {
  id        String   @id @default(uuid())
  guildId   String
  userId    String   // Discord user ID
  channelId String   // Channel where reminder was set
  message   String   // Reminder text
  remindAt  DateTime // When to fire the reminder
  fired     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([remindAt, fired])
  @@index([userId, guildId])
  @@map("reminders")
}

// ─── Rifa Module ─────────────────────────────────────────────
model Rifa {
  id             String   @id @default(uuid())
  guildId        String
  guild          GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId      String
  messageId      String?
  hostId         String
  prize          String
  description    String?
  maxSlots       Int
  participants   String[] @default([])
  winnerIds      String[] @default([])
  winnersCount   Int      @default(1)
  endsAt         DateTime?
  ended          Boolean  @default(false)
  cancelled      Boolean  @default(false)
  autoDrawOnFull Boolean  @default(false)
  allowSelfJoin  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())

  @@index([guildId])
  @@index([endsAt])
  @@map("rifas")
}

// ─── Command Permissions ──────────────────────────────────────
model CommandPermission {
  id        String      @id @default(uuid())
  guildId   String
  guild     GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  command   String
  roleIds   String[]    @default([])
  disabled  Boolean     @default(false)
  updatedAt DateTime    @updatedAt @default(now())

  @@unique([guildId, command])
  @@map("command_permissions")
}

// ─── Member Levels / XP ──────────────────────────────────────