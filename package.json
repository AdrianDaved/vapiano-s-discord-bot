{
  "name": "vapiano-bot",
  "version": "1.0.0",
  "description": "All-in-one Discord bot: invites, backups, leveling, moderation, automation, tickets + web dashboard",
  "main": "dist/bot/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot/index.js",
    "dev": "tsx watch src/bot/index.ts",
    "api": "tsx watch src/api/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run api\" \"npm run dashboard:dev\"",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "deploy:commands": "tsx src/bot/deploy-commands.ts",
    "lint": "eslint src --ext .ts",
    "setup": "npm run build && npm run dashboard:build && npm run db:push",
    "start:prod": "concurrently \"node dist/bot/index.js\" \"node dist/api/index.js\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@discordjs/rest": "^2.4.0",
    "@napi-rs/canvas": "^0.1.96",
    "@prisma/client": "^5.22.0",
    "concurrently": "^9.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "ms": "^2.1.3",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "uuid": "^10.0.0",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/ms": "^0.7.34",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.16",
    "@types/passport-discord": "^0.1.13",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.14.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
